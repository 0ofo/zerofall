<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avaloniaEdit="using:AvaloniaEdit"
             xmlns:views="using:ZeroFall.SqlEditor.Views"
             x:Class="ZeroFall.SqlEditor.Views.FilePreviewView"
             x:DataType="x:Object">

    <Grid>
        <avaloniaEdit:TextEditor x:Name="TextEditor"
                                 Margin="0"
                                 Padding="4"
                                 FontFamily="Consolas,Courier New,monospace"
                                 FontSize="13"
                                 Foreground="{DynamicResource SemiColorText0}"
                                 Background="{DynamicResource SemiColorBackground0}"
                                 ShowLineNumbers="True"
                                 WordWrap="False"
                                 IsReadOnly="False"/>
        <ContentControl x:Name="TableContent"/>
        <views:MarkdownPreviewView x:Name="MarkdownPreview" IsVisible="False"/>
    </Grid>
</UserControl>
