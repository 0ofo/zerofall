<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeroFall.App.ViewModels"
             x:Class="ZeroFall.App.Views.WorkspaceHomeView"
             x:DataType="vm:WorkspaceHomeViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Border Background="{DynamicResource PanelBackgroundBrush}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    MaxWidth="560">
            <TextBlock Text="烬"
                       FontSize="28"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="ZeroFall"
                       FontSize="14"
                       Opacity="0.65"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding HintText}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Opacity="0.8"
                       HorizontalAlignment="Center"/>
            <WrapPanel HorizontalAlignment="Center"
                       Margin="0,8,0,0">
                <Button Content="打开项目文件夹"
                        Command="{Binding OpenProjectFolderCommand}"
                        IsVisible="{Binding ShowOpenProjectFolder}"
                        Theme="{DynamicResource SolidButton}"
                        Margin="6"/>
                <Button Content="打开文件"
                        Command="{Binding OpenFileCommand}"
                        Margin="6"/>
                <Button Content="打开浏览器"
                        Command="{Binding OpenBrowserCommand}"
                        Margin="6"/>
                <Button Content="打开终端"
                        Command="{Binding OpenTerminalCommand}"
                        Margin="6"/>
                <Button Content="打开资产侦察"
                        Command="{Binding OpenAssetReconCommand}"
                        Margin="6"/>
                <Button Content="打开设置"
                        Command="{Binding OpenSettingsCommand}"
                        Margin="6"/>
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>
