<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 紧凑型上下文菜单 -->
    <Style Selector="ContextMenu">
        <Setter Property="Padding" Value="2"/>
        <Setter Property="CornerRadius" Value="{DynamicResource SemiBorderRadiusSmall}"/>
        <Setter Property="MinWidth" Value="120"/>
    </Style>
    <Style Selector="MenuItem">
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="MinHeight" Value="{DynamicResource SemiHeightControlSmall}"/>
        <Setter Property="FontSize" Value="{DynamicResource SemiFontSizeSmall}"/>
    </Style>
    <Style Selector="MenuItem > StackPanel > TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource SemiFontSizeSmall}"/>
    </Style>
    <Style Selector="MenuItem:separator">
        <Setter Property="Margin" Value="4,2"/>
        <Setter Property="Height" Value="1"/>
    </Style>
</Styles>
