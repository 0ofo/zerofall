<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeroFall.AiPanel.ViewModels"
             x:Class="ZeroFall.AiPanel.Views.ReconPaidConfirmDialogView"
             x:DataType="vm:ReconPaidConfirmDialogViewModel"
             MaxWidth="360">
    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
        <TextBlock Grid.Row="0"
                   Text="{Binding Summary}"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="1"
                   Text="查询语句"
                   Opacity="0.75"
                   FontSize="12"/>

        <TextBox Grid.Row="2"
                 Text="{Binding Query}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="36"/>
    </Grid>
</UserControl>
