<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:Avalonia.Data.Converters"
             xmlns:vm="using:ZeroFall.Browser.ViewModels"
             x:Class="ZeroFall.Browser.Views.WebsiteTreeView"
             x:DataType="vm:WebsiteTreeViewModel">
    <UserControl.Resources>
        <ContextMenu x:Key="WebsiteTreeContextMenu"
                     x:CompileBindings="False"
                     Opening="WebsiteTree_ContextMenuOpening">
            <MenuItem Header="复制 URL"
                      Classes="Small"
                      Click="WebsiteTreeMenu_CopyUrl"/>
            <MenuItem Header="发送到 HTTP 重放"
                      Classes="Small"
                      Click="WebsiteTreeMenu_SendReplay"/>
            <Separator/>
            <MenuItem x:Name="ProbeTechnologiesMenuItem"
                      Header="主动探测技术栈"
                      Classes="Small"
                      Click="WebsiteTreeMenu_ProbeTechnologies"/>
            <MenuItem x:Name="ToggleActiveProbeMenuItem"
                      Header="开启主动探测辅助"
                      Classes="Small"
                      Click="WebsiteTreeMenu_ToggleActiveProbe"/>
            <Separator/>
            <MenuItem x:Name="AddToTargetScopeMenuItem"
                      Header="添加到目标空间"
                      Classes="Small"
                      Click="WebsiteTreeMenu_AddToTargetScope"/>
            <MenuItem x:Name="RemoveFromTargetScopeMenuItem"
                      Header="从目标空间移除"
                      Classes="Small"
                      Click="WebsiteTreeMenu_RemoveFromTargetScope"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid RowDefinitions="*">
        <TreeView x:Name="WebsiteTree"
                  ItemsSource="{Binding RootNodes}"
                  SelectedItem="{Binding SelectedNode}"
                  ContextMenu="{StaticResource WebsiteTreeContextMenu}"
                  HorizontalAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <TreeView.Styles>
                <Style Selector="TreeView /template/ ScrollViewer#PART_ScrollViewer">
                    <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                </Style>
                <Style Selector="TreeViewItem" x:CompileBindings="False">
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
                <TreeDataTemplate x:DataType="vm:WebsiteTreeNodeViewModel"
                                  ItemsSource="{Binding Children}"
                                  x:CompileBindings="False">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <PathIcon Data="{Binding ItemIcon}"
                                  Width="14"
                                  Height="14"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource SemiColorText2}"
                                  IsVisible="{Binding ItemIcon, Converter={x:Static c:ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="{Binding Title}"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
