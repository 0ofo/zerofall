<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:ZeroFall.Browser.Views"
        xmlns:vm="using:ZeroFall.Browser.ViewModels"
        x:Class="ZeroFall.Browser.Views.TrafficFilterDialog"
        x:Name="FilterDialogWindow"
        x:DataType="vm:TrafficFilterDialogViewModel"
        Title="HTTP 历史记录筛选"
        Width="980"
        MinWidth="860"
        MaxHeight="640"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        x:CompileBindings="False">

    <Grid RowDefinitions="Auto,Auto">
        <views:TrafficFilterView Grid.Row="0"
                                 Margin="16,10,16,0"/>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,1,0,0"
                Margin="0,10,0,0"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Content="全部显示" Classes="Small" Command="{Binding ShowAllCommand}"/>
                    <Button Content="全部隐藏" Classes="Small" Command="{Binding HideAllCommand}"/>
                    <Button Content="撤销更改" Classes="Small" Command="{Binding RevertChangesCommand}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Content="取消"
                            Classes="Small"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding #FilterDialogWindow}"/>
                    <Button Content="应用"
                            Classes="Small"
                            Command="{Binding ApplyCommand}"/>
                    <Button Content="应用并关闭"
                            Classes="Small"
                            Theme="{DynamicResource SolidButton}"
                            Command="{Binding ApplyAndCloseCommand}"
                            CommandParameter="{Binding #FilterDialogWindow}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
