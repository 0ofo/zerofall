<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="using:ZeroFall.Browser.ViewModels"
             x:Class="ZeroFall.Browser.Views.TrafficFilterView"
             x:DataType="vm:TrafficFilterDialogViewModel"
             x:CompileBindings="False">
    <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="8">
            <u:UrsaGroupBox Grid.Column="0" Header="按请求类型筛选" VerticalAlignment="Top">
                <StackPanel Spacing="4">
                    <CheckBox Content="仅显示范围内条目" IsChecked="{Binding ShowOnlyInScope}"/>
                    <CheckBox Content="隐藏无响应的条目" IsChecked="{Binding HideWithoutResponse}"/>
                    <CheckBox Content="仅显示带参数的请求" IsChecked="{Binding ShowOnlyParameterized}"/>
                </StackPanel>
            </u:UrsaGroupBox>

            <u:UrsaGroupBox Grid.Column="1" Header="按 MIME 类型筛选" VerticalAlignment="Top">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="4">
                    <CheckBox Grid.Row="0" Grid.Column="0" Content="HTML" IsChecked="{Binding MimeHtml}"/>
                    <CheckBox Grid.Row="0" Grid.Column="1" Content="其他文本" IsChecked="{Binding MimeOtherText}"/>
                    <CheckBox Grid.Row="1" Grid.Column="0" Content="脚本" IsChecked="{Binding MimeScript}"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" Content="图片" IsChecked="{Binding MimeImages}"/>
                    <CheckBox Grid.Row="2" Grid.Column="0" Content="XML" IsChecked="{Binding MimeXml}"/>
                    <CheckBox Grid.Row="2" Grid.Column="1" Content="Flash" IsChecked="{Binding MimeFlash}"/>
                    <CheckBox Grid.Row="3" Grid.Column="0" Content="CSS" IsChecked="{Binding MimeCss}"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" Content="其他二进制" IsChecked="{Binding MimeOtherBinary}"/>
                </Grid>
            </u:UrsaGroupBox>

            <u:UrsaGroupBox Grid.Column="2" Header="按状态码筛选" VerticalAlignment="Top">
                <StackPanel Spacing="4">
                    <CheckBox Content="2xx [成功]" IsChecked="{Binding Status2xx}"/>
                    <CheckBox Content="3xx [重定向]" IsChecked="{Binding Status3xx}"/>
                    <CheckBox Content="4xx [请求错误]" IsChecked="{Binding Status4xx}"/>
                    <CheckBox Content="5xx [服务器错误]" IsChecked="{Binding Status5xx}"/>
                </StackPanel>
            </u:UrsaGroupBox>
        </Grid>

        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto" ColumnSpacing="8">
            <u:UrsaGroupBox Grid.Column="0" Header="按搜索词筛选" VerticalAlignment="Top">
                <StackPanel Spacing="4">
                    <TextBox Text="{Binding SearchTerm}"
                             PlaceholderText="搜索词"
                             Classes="Small"/>
                    <CheckBox Content="正则表达式" IsChecked="{Binding SearchRegex}"/>
                    <CheckBox Content="区分大小写" IsChecked="{Binding SearchCaseSensitive}"/>
                    <CheckBox Content="反向搜索" IsChecked="{Binding SearchNegative}"/>
                </StackPanel>
            </u:UrsaGroupBox>

            <u:UrsaGroupBox Grid.Column="1" Header="按文件扩展名筛选" VerticalAlignment="Top">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding ExtensionShowOnlyEnabled}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="仅显示" Opacity="0.75" FontSize="11"/>
                            <TextBox Text="{Binding ExtensionShowOnly}"
                                     Classes="Small"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding ExtensionHideEnabled}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="隐藏" Opacity="0.75" FontSize="11"/>
                            <TextBox Text="{Binding ExtensionHide}"
                                     Classes="Small"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </u:UrsaGroupBox>

            <u:UrsaGroupBox Grid.Column="2" Header="按标注筛选" VerticalAlignment="Top">
                <StackPanel Spacing="4">
                    <CheckBox Content="仅显示有备注的条目"
                              IsChecked="{Binding ShowOnlyWithNotes}"/>
                    <CheckBox Content="仅显示高亮条目"
                              IsChecked="{Binding ShowOnlyHighlighted}"/>
                </StackPanel>
            </u:UrsaGroupBox>

            <u:UrsaGroupBox Grid.Column="3" Header="按监听器筛选" VerticalAlignment="Top">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0"
                               Text="端口"
                               VerticalAlignment="Center"
                               Opacity="0.75"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding ListenerPort}"
                             PlaceholderText="8080"
                             Classes="Small"/>
                </Grid>
            </u:UrsaGroupBox>
        </Grid>
    </StackPanel>
</UserControl>
