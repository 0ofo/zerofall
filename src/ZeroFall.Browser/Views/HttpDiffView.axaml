<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeroFall.Browser.ViewModels"
             x:Class="ZeroFall.Browser.Views.HttpDiffView"
             x:DataType="vm:HttpDiffTabViewModel">
    <Grid Margin="8" RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,0,0,4">
            <TextBlock Grid.Column="0"
                       Text="{Binding LeftLabel}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding RightLabel}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Grid>
        <TextBlock Grid.Row="1"
                   Text="{Binding SummaryText}"
                   FontSize="11"
                   Opacity="0.75"
                   Margin="0,0,0,8"/>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Lines}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 x:CompileBindings="False">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:HttpDiffLineViewModel" x:CompileBindings="False">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                        <Border Grid.Column="0"
                                Background="{Binding LeftBackground}"
                                Padding="4,1">
                            <TextBlock Text="{Binding Left}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="12"
                                       TextWrapping="NoWrap"/>
                        </Border>
                        <Border Grid.Column="1"
                                Background="{Binding RightBackground}"
                                Padding="4,1">
                            <TextBlock Text="{Binding Right}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="12"
                                       TextWrapping="NoWrap"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
